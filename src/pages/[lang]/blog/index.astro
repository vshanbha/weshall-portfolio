---
import { getStaticPathsHelper } from '@/i18n/paths-helper';
import PageLayout from '@/layouts/PageLayout.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '@/i18n/index';
import { defaultLocale } from '@/i18n/config';

export const getStaticPaths = getStaticPathsHelper;

const { lang } = Astro.params;
const locale = lang as Locale;
const t = useTranslations(locale);

const allEntries = await getCollection('articles', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const localeEntries = allEntries.filter((e) => {
  const articleLocale = e.data.locale || defaultLocale;
  return articleLocale === locale;
});

const sorted = localeEntries.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
});
---

<PageLayout
  title={t('blog.title')}
  description={t('blog.description')}
>
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl text-center">
        {t('blog.title')}
      </h1>
      <p class="mt-4 text-lg text-muted-foreground max-w-2xl mx-auto text-center">
        {t('blog.description')}
      </p>

      {sorted.length > 0 ? (
        <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {sorted.map((entry) => (
            <BlogCard
              title={entry.data.title}
              description={entry.data.description}
              href={`/${locale}/blog/${entry.id}/`}
              publishedAt={entry.data.publishedAt}
              tags={entry.data.tags}
              author={entry.data.author}
              image={entry.data.image}
              featured={entry.data.featured}
            />
          ))}
        </div>
      ) : (
        <p class="mt-16 text-center text-muted-foreground">
          {t('blog.noPosts')}
        </p>
      )}
    </div>
  </section>
</PageLayout>
