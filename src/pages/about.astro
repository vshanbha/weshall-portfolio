---
import PageLayout from '@/layouts/PageLayout.astro';
import { useTranslations, getTranslations } from '@/i18n/index';
import { getLocaleFromPath } from '@/i18n/config';
import { Image } from 'astro:assets';
import photo from '@/assets/photo.jpg';
import Button from '@/components/ui/form/Button/Button.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { createPersonSchema } from '@/lib/schema';
import type { TranslationKeys } from '@/i18n/translations/en';

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const tr = getTranslations(locale) as TranslationKeys;
---

<PageLayout
  title={t('about.meta.title')}
  description={t('about.meta.description')}
>
  <!-- Section 1 — Origin (hero with portrait) -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-[1fr_2fr] gap-12 items-start max-w-4xl mx-auto">
        <div>
          <Image src={photo} alt="Vishal Shanbhag" class="rounded-lg w-full max-w-sm" />
        </div>
        <div>
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl font-display text-balance mb-8">
            {t('about.origin.title')}
          </h1>
          {tr.about.origin.paragraphs.map((p) => (
            <p class="mb-4 text-muted-foreground leading-relaxed">{p}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2 — What I do -->
  <section class="py-16 md:py-24 bg-muted/50">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold font-display mb-8">{t('about.whatido.title')}</h2>
      {tr.about.whatido.paragraphs.map((p) => (
        <p class="mb-4 text-muted-foreground leading-relaxed">{p}</p>
      ))}
    </div>
  </section>

  <!-- Section 3 — The career arc, briefly -->
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold font-display mb-8">{t('about.careerarc.title')}</h2>
      {tr.about.careerarc.paragraphs.map((p) => (
        <p class="mb-4 text-muted-foreground leading-relaxed" set:html={p}></p>
      ))}
      {tr.about.careerarc.highlights.map((h) => (
        <div class="mb-4">
          <strong class="text-foreground font-semibold">{h.name}</strong>
          <span class="text-muted-foreground leading-relaxed">{h.description}</span>
        </div>
      ))}
      <p class="mb-4 text-muted-foreground leading-relaxed" set:html={t('about.careerarc.earlier')}></p>
      <p class="text-muted-foreground leading-relaxed">
        <a
          href={t('about.careerarc.linkedin.url')}
          class="underline underline-offset-2 hover:text-primary transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t('about.careerarc.linkedin.text')}
        </a>
        {t('about.careerarc.linkedin.note')}
      </p>
    </div>
  </section>

  <!-- Section 4 — Speaking, writing, mentorship -->
  <section class="py-16 md:py-24 bg-muted/50">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold font-display mb-4">{t('about.speaking.title')}</h2>
      <p class="text-muted-foreground mb-8">{t('about.speaking.articles.intro')}</p>
      <h3 class="text-xl font-semibold font-display mb-4">{t('about.speaking.articles.title')}</h3>
      <ol class="space-y-3 list-decimal list-inside">
        {tr.about.speaking.articles.items.map((item) => (
          <li class="text-muted-foreground">
            {item.url ? (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-primary underline underline-offset-2 transition-colors"
              >
                {item.title}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="inline-block w-3.5 h-3.5 ml-1 align-text-bottom"
                  aria-hidden="true"
                >
                  <path d="M7 17L17 7" />
                  <path d="M7 7h10v10" />
                </svg>
              </a>
            ) : (
              <span>{item.title}</span>
            )}
            <span class="inline-flex items-center rounded-full bg-secondary px-2.5 py-0.5 text-xs font-medium text-secondary-foreground ml-2">
              {item.platform}
            </span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Section 5 — Off the clock -->
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold font-display mb-8">{t('about.offtheclock.title')}</h2>
      {tr.about.offtheclock.paragraphs.map((p) => (
        <p class="mb-4 text-muted-foreground leading-relaxed">{p}</p>
      ))}
      <p class="mt-8 text-lg font-medium">
        {t('about.offtheclock.closingLead')}
        <a href="/contact" class="underline underline-offset-2 hover:text-primary transition-colors">{t('about.offtheclock.closing')}</a>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <CTA variant="default" size="lg">
    <Fragment slot="heading">
      <h2 class="text-3xl font-bold font-display text-balance">{t('about.cta.title')}</h2>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/contact" variant="primary" size="lg">
        {t('about.cta.button')}
      </Button>
    </Fragment>
  </CTA>

  <JsonLd schema={createPersonSchema()} />
</PageLayout>