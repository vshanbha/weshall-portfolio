---
import PageLayout from '@/layouts/PageLayout.astro';
import { useTranslations } from '@/i18n/index';
import { getLocaleFromPath } from '@/i18n/config';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
import Accordion from '@/components/ui/overlay/Accordion/Accordion.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { createPersonSchema } from '@/lib/schema';

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const competencyIcons = ['code', 'zap', 'box', 'layers', 'users'];

const experienceItems = [0, 1, 2, 3].map((i) => ({
  title: `${t(`about.experience.items.${i}.role`)} \u00b7 ${t(`about.experience.items.${i}.company`)}`,
  content: t(`about.experience.items.${i}.summary`),
}));
---

<PageLayout
  title={t('about.meta.title')}
  description={t('about.meta.description')}
>
  <!-- Hero -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
        {t('about.hero.title')} <span class="text-muted-foreground">{t('about.hero.titleHighlight')}</span>
      </h1>
      <p class="mt-6 text-lg text-muted-foreground max-w-2xl mx-auto text-balance">
        {t('about.hero.description')}
      </p>
    </div>
  </section>

  <!-- Core Competencies -->
  <section class="py-16 md:py-24 bg-muted/50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{t('about.competencies.title')}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[0, 1, 2, 3, 4].map((i) => (
          <Card variant="default" padding="md" hover>
            <div class="flex items-start gap-4">
              <div class="p-2.5 rounded-lg bg-muted shrink-0">
                <Icon name={competencyIcons[i]} size="md" />
              </div>
              <div>
                <h3 class="font-semibold mb-1">{t(`about.competencies.items.${i}.title`)}</h3>
                <p class="text-sm text-muted-foreground leading-relaxed">{t(`about.competencies.items.${i}.description`)}</p>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Selected Experience -->
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold text-center mb-12">{t('about.experience.title')}</h2>
      <Accordion items={experienceItems} variant="card" size="md" exclusive />
    </div>
  </section>

  <!-- Publications & Speaking -->
  <section class="py-16 md:py-24 bg-muted/50">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold text-center mb-12">{t('about.publications.title')}</h2>
      <Card variant="default" padding="lg">
        <ul class="space-y-4">
          {[0, 1, 2, 3, 4, 5].map((i) => {
            const pubTitle = t(`about.publications.items.${i}.title`);
            const pubUrl = t(`about.publications.items.${i}.url`);
            const pubPlatform = t(`about.publications.items.${i}.platform`);
            if (!pubTitle) return null;
            return (
              <li class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  {pubUrl ? (
                    <a href={pubUrl} target="_blank" rel="noopener noreferrer" class="hover:text-primary underline underline-offset-2 transition-colors">
                      {pubTitle}
                      <Icon name="external-link" size="xs" class="inline ml-1" />
                    </a>
                  ) : (
                    <span>{pubTitle}</span>
                  )}
                </div>
                <Badge variant="default" size="sm" pill>{pubPlatform}</Badge>
              </li>
            );
          })}
        </ul>
      </Card>
    </div>
  </section>

  <!-- Engineering Philosophy -->
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl font-bold text-center mb-12">{t('about.philosophy.title')}</h2>
      <Card variant="ghost" padding="lg">
        <div class="space-y-8">
          {[0, 1, 2].map((i) => (
            <blockquote class="border-l-4 border-primary pl-6 text-lg text-muted-foreground italic leading-relaxed">
              &ldquo;{t(`about.philosophy.quotes.${i}`)}&rdquo;
            </blockquote>
          ))}
        </div>
      </Card>
    </div>
  </section>

  <!-- CTA -->
  <CTA variant="default" size="lg">
    <Fragment slot="heading">
      <h2>{t('about.cta.title')}</h2>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/contact" variant="primary" size="lg">
        {t('about.cta.button')}
      </Button>
    </Fragment>
  </CTA>

  <JsonLd schema={createPersonSchema()} />
</PageLayout>
