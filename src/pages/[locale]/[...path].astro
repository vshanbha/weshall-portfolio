---
import type { GetStaticPaths } from 'astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import BlogLayout from '@/layouts/BlogLayout.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { useTranslations, getTranslations } from '@/i18n/index';
import type { TranslationKeys } from '@/i18n/translations/en';
import { defaultLocale, type Locale, locales } from '@/i18n/config';
import { routes } from '@/i18n/routes';
import siteConfig from '@/config/site.config';
import { createBlogPostSchema, createServiceSchema } from '@/lib/schema';

export const getStaticPaths: GetStaticPaths = async () => {
  const nonDefaultLocales = locales.filter((l) => l !== defaultLocale);
  const paths: Array<{ params: { locale: string; path?: string }; props: Record<string, unknown> }> = [];

  for (const locale of nonDefaultLocales) {
    paths.push({
      params: { locale, path: undefined },
      props: { type: 'home', locale },
    });

    for (const [routeId, routeDef] of Object.entries(routes)) {
      if (routeId === 'home') continue;
      paths.push({
        params: { locale, path: routeDef[locale as Locale] },
        props: { type: 'page', routeId, locale },
      });
    }

    const localeArticles = await getCollection('articles', ({ data }) => {
      const notDraft = import.meta.env.PROD ? data.draft !== true : true;
      const matchesLocale = data.locale === locale || !data.locale;
      return notDraft && matchesLocale;
    });

    for (const entry of localeArticles) {
      paths.push({
        params: { locale, path: `blog/${entry.id}` },
        props: { type: 'article', entry, locale },
      });
    }
  }

  return paths;
};

const { locale } = Astro.params;
const type = (Astro.props as { type?: string }).type || 'unknown';
const resolvedLocale = (locale || defaultLocale) as Locale;
const t = useTranslations(resolvedLocale);
const tr = getTranslations(resolvedLocale) as TranslationKeys;

const isHome = type === 'home';
const isPage = type === 'page';
const isArticle = type === 'article';

const routeId = (Astro.props as { routeId?: string }).routeId;
const entry = (Astro.props as { entry?: CollectionEntry<'articles'> }).entry;

// Fetch blog listing data if needed (also used for static generation)
let blogEntries: CollectionEntry<'articles'>[] = [];
if (isHome || isPage) {
  const allEntries = await getCollection('articles', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  blogEntries = allEntries
    .filter((e) => {
      const articleLocale = e.data.locale || defaultLocale;
      return articleLocale === resolvedLocale;
    })
    .sort((a, b) => {
      if (a.data.featured && !b.data.featured) return -1;
      if (!a.data.featured && b.data.featured) return 1;
      return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
    });
}

let articleEntry: CollectionEntry<'articles'> | null = null;
let Content: any = null;
let canonicalUrl: URL | null = null;
let ogImageUrl: string | null = null;

if (isArticle && entry) {
  articleEntry = entry;
  const rendered = await render(articleEntry);
  Content = rendered.Content;
  canonicalUrl = new URL(`/${resolvedLocale}/blog/${articleEntry.id}/`, Astro.site);
  const img = articleEntry.data.image;
  ogImageUrl = img
    ? typeof img === 'string' ? img : img.src
    : `/og/${resolvedLocale}/blog/${articleEntry.id}.png`;
}
---

{
  isHome ? (
    <PageLayout title={t('site.name')} description={t('site.description')}>
      <CTA variant="default" size="xl">
        <Fragment slot="heading">
          <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-balance text-foreground">{t('hero.title')}</h1>
        </Fragment>
        <Fragment slot="description">
          <p>{t('hero.bridge')}</p>
        </Fragment>
        <Fragment slot="actions">
          <Button variant="primary" size="lg" href={`/${resolvedLocale}/contact`}>
            {t('hero.cta.primary')}
          </Button>
          <Button variant="outline" size="lg" href={`/${resolvedLocale}/blog`}>
            {t('hero.cta.secondary')}
          </Button>
        </Fragment>
      </CTA>

      <section class="py-16 md:py-24 bg-muted/50">
        <div class="container mx-auto px-4">
          <h2 class="text-3xl font-bold font-display text-center mb-12">
            {t('home.stories.title')}
          </h2>
          <div class="grid gap-8 md:grid-cols-3 max-w-6xl mx-auto auto-rows-fr">
            {(tr.home.stories.items as unknown as any[]).map((item: { title: string; subtitle: string; href: string; paragraphs: string[] }) => (
              <a href={`/${resolvedLocale}${item.href}`} class="block h-full no-underline group">
                <Card variant="default" padding="lg" class="h-full flex flex-col transition-all duration-200 group-hover:shadow-md group-hover:-translate-y-0.5">
                  <div>
                    <h3 class="text-lg font-semibold mb-1 group-hover:text-primary transition-colors">
                      {item.title}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block w-4 h-4 ml-1 align-text-bottom opacity-0 group-hover:opacity-100 transition-opacity" aria-hidden="true">
                        <path d="M7 17L17 7" />
                        <path d="M7 7h10v10" />
                      </svg>
                    </h3>
                    <p class="text-xs text-muted-foreground mb-4">{item.subtitle}</p>
                  </div>
                  <div class="space-y-3 flex-1">
                    {item.paragraphs.map((p: string) => (
                      <p class="text-sm text-muted-foreground leading-relaxed">{p}</p>
                    ))}
                  </div>
                </Card>
              </a>
            ))}
          </div>
        </div>
      </section>

      <CTA variant="default" size="lg">
        <Fragment slot="heading">
          <h2>{t('cta.title')}</h2>
        </Fragment>
        <Fragment slot="description">
          <p>{t('cta.description')}</p>
        </Fragment>
        <Fragment slot="actions">
          <Button variant="primary" size="lg" href={`/${resolvedLocale}/contact`}>
            {t('cta.button')}
          </Button>
        </Fragment>
      </CTA>
    </PageLayout>
  ) : isPage && routeId === 'about' ? (
    <PageLayout title={t('about.meta.title')} description={t('about.meta.description')}>
      <section class="py-24 md:py-32">
        <div class="container mx-auto px-4 max-w-3xl">
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl font-display text-balance mb-8">
            {t('about.origin.title')}
          </h1>
          {tr.about.origin.paragraphs.map((p: string) => (
            <p class="mb-4 text-muted-foreground leading-relaxed">{p}</p>
          ))}
        </div>
      </section>
    </PageLayout>
  ) : isPage && routeId === 'contact' ? (
    <PageLayout title={t('contact.meta.title')} description={t('contact.meta.description')}>
      <section class="py-24 md:py-32">
        <div class="container mx-auto px-4 text-center max-w-3xl">
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl font-display text-balance mb-8">
            {t('contact.hero.title')}
          </h1>
          <p class="text-lg text-muted-foreground text-balance mx-auto max-w-2xl">
            {t('contact.hero.description')}
          </p>
        </div>
      </section>
      <section class="py-16 md:py-24 bg-muted/50">
        <div class="container mx-auto px-4 max-w-4xl">
          <div class="grid gap-8 md:grid-cols-2">
            <Card variant="default" padding="lg" class="flex flex-col">
              <h2 class="text-2xl font-bold font-display mb-4">{t('contact.linkedin.title')}</h2>
              <p class="text-muted-foreground mb-6 flex-1">{t('contact.linkedin.description')}</p>
              <Button variant="primary" size="lg" href={t('contact.linkedin.url')}>
                {t('contact.linkedin.button')}
              </Button>
            </Card>
            <Card variant="default" padding="lg" class="flex flex-col">
              <h2 class="text-2xl font-bold font-display mb-4">{t('contact.upwork.title')}</h2>
              <p class="text-muted-foreground mb-6 flex-1">{t('contact.upwork.description')}</p>
              <Button variant="outline" size="lg" href={t('contact.upwork.url')}>
                {t('contact.upwork.button')}
              </Button>
            </Card>
          </div>
        </div>
      </section>
      <section class="py-16 md:py-24">
        <div class="container mx-auto px-4 text-center max-w-xl">
          <h2 class="text-xl font-semibold font-display mb-4">{t('contact.direct.title')}</h2>
          <p class="text-muted-foreground">
            Email: <a href={`mailto:${t('contact.direct.email')}`} class="underline underline-offset-2 hover:text-primary transition-colors">{t('contact.direct.email')}</a>
          </p>
          <p class="text-muted-foreground mt-2">
            GitHub: <a href={`https://${t('contact.direct.github')}`} target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-primary transition-colors">{t('contact.direct.github')}</a>
          </p>
        </div>
      </section>
    </PageLayout>
  ) : isPage && routeId === 'services' ? (
    <PageLayout title={t('services.meta.title')} description={t('services.meta.description')}>
      <section class="py-24 md:py-32">
        <div class="container mx-auto px-4 text-center">
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl font-display text-balance">
            {t('services.hero.title')}
          </h1>
          <p class="mt-6 text-lg text-muted-foreground max-w-2xl mx-auto text-balance">
            {t('services.hero.description')}
          </p>
        </div>
      </section>

      <section class="py-16 md:py-24 bg-muted/50">
        <div class="container mx-auto px-4 max-w-3xl">
          <h2 class="text-3xl font-bold font-display text-center mb-8">
            {t('services.howwork.title')}
          </h2>
          {tr.services.howwork.paragraphs.map((p: string) => (
            <p class="mb-4 text-muted-foreground leading-relaxed">{p}</p>
          ))}
        </div>
      </section>

      <CTA variant="default" size="lg">
        <Fragment slot="heading">
          <h2 class="text-3xl font-bold font-display text-balance">{t('services.cta.title')}</h2>
        </Fragment>
        <Fragment slot="description">
          <p>{t('services.cta.description')}</p>
        </Fragment>
        <Fragment slot="actions">
          <Button href={`/${resolvedLocale}/contact`} variant="primary" size="lg">
            {t('services.cta.button')}
          </Button>
        </Fragment>
      </CTA>

      <JsonLd schema={createServiceSchema()} />
    </PageLayout>
  ) : isPage && routeId === 'blog' ? (
    <PageLayout title={t('blog.title')} description={t('blog.description')}>
      <section class="py-24 md:py-32">
        <div class="container mx-auto px-4">
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl text-center">
            {t('blog.title')}
          </h1>
          <p class="mt-4 text-lg text-muted-foreground max-w-2xl mx-auto text-center">
            {t('blog.description')}
          </p>
          {blogEntries.length > 0 ? (
            <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {blogEntries.map((entry) => (
                <BlogCard
                  title={entry.data.title}
                  description={entry.data.description}
                  href={`/${resolvedLocale}/blog/${entry.id}/`}
                  publishedAt={entry.data.publishedAt}
                  tags={entry.data.tags}
                  author={entry.data.author}
                  image={entry.data.image}
                  featured={entry.data.featured}
                />
              ))}
            </div>
          ) : (
            <p class="mt-16 text-center text-muted-foreground">{t('blog.noPosts')}</p>
          )}
        </div>
      </section>
    </PageLayout>
  ) : isArticle && articleEntry && Content ? (
    <BlogLayout
      title={`${articleEntry.data.title} — ${siteConfig.name}`}
      description={articleEntry.data.description}
      publishedAt={articleEntry.data.publishedAt}
      updatedAt={articleEntry.data.updatedAt}
      author={articleEntry.data.author}
      image={ogImageUrl!}
      imageAlt={articleEntry.data.imageAlt}
      tags={articleEntry.data.tags}
      slug={articleEntry.id}
      locale={resolvedLocale}
    >
      <JsonLd
        schema={createBlogPostSchema({
          title: articleEntry.data.title,
          description: articleEntry.data.description,
          url: canonicalUrl!.toString(),
          image: ogImageUrl!,
          datePublished: articleEntry.data.publishedAt,
          dateModified: articleEntry.data.updatedAt || articleEntry.data.publishedAt,
          author: { name: articleEntry.data.author },
        })}
      />
      <Content />
    </BlogLayout>
  ) : (
    <PageLayout title="404" description="Not found">
      <section class="py-24 md:py-32 text-center">
        <h1 class="text-4xl font-bold">404</h1>
        <p class="mt-4 text-lg text-muted-foreground">{t('common.notFound')}</p>
      </section>
    </PageLayout>
  )
}
---
