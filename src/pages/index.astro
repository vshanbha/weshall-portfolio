---
import PageLayout from '@/layouts/PageLayout.astro';
import { useTranslations, getTranslations } from '@/i18n/index';
import { getLocaleFromPath } from '@/i18n/config';
import Button from '@/components/ui/form/Button/Button.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
import type { TranslationKeys } from '@/i18n/translations/en';

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const tr = getTranslations(locale) as TranslationKeys;
---

<PageLayout
  title={t('site.name')}
  description={t('site.description')}
>
  <CTA variant="default" size="xl">
    <Fragment slot="heading">
      <h1>{t('hero.title')}</h1>
    </Fragment>
    <Fragment slot="description">
      <p>{t('hero.bridge')}</p>
    </Fragment>
    <Fragment slot="actions">
      <Button variant="primary" size="lg" href="/contact">
        {t('hero.cta.primary')}
      </Button>
      <Button variant="outline" size="lg" href="/blog">
        {t('hero.cta.secondary')}
      </Button>
    </Fragment>
  </CTA>

  <section class="py-16 md:py-24 bg-muted/50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold font-display text-center mb-12">
        {t('home.stories.title')}
      </h2>
      <div class="grid gap-8 md:grid-cols-3 max-w-6xl mx-auto auto-rows-fr">
        {(tr.home.stories.items as unknown as any[]).map((item: { title: string; subtitle: string; href: string; paragraphs: string[] }) => (
          <a href={item.href} class="block h-full no-underline group">
            <Card variant="default" padding="lg" class="h-full flex flex-col transition-all duration-200 group-hover:shadow-md group-hover:-translate-y-0.5">
              <div>
                <h3 class="text-lg font-semibold mb-1 group-hover:text-primary transition-colors">
                  {item.title}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block w-4 h-4 ml-1 align-text-bottom opacity-0 group-hover:opacity-100 transition-opacity" aria-hidden="true">
                    <path d="M7 17L17 7" />
                    <path d="M7 7h10v10" />
                  </svg>
                </h3>
                <p class="text-xs text-muted-foreground mb-4">{item.subtitle}</p>
              </div>
              <div class="space-y-3 flex-1">
                {item.paragraphs.map((p: string) => (
                  <p class="text-sm text-muted-foreground leading-relaxed">{p}</p>
                ))}
              </div>
            </Card>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA variant="default" size="lg">
    <Fragment slot="heading">
      <h2>{t('cta.title')}</h2>
    </Fragment>
    <Fragment slot="description">
      <p>{t('cta.description')}</p>
    </Fragment>
    <Fragment slot="actions">
      <Button variant="primary" size="lg" href="/contact">
        {t('cta.button')}
      </Button>
    </Fragment>
  </CTA>
</PageLayout>